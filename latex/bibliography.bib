	file = {PDF:/home/admin/Zotero/storage/CL4NLCQ7/Luo et al. - 2020 - Inverse Reinforcement Learning for Team Sports Valuing Actions and Players.pdf:application/pdf},
}

@misc{terner_modeling_2020,
