@article{ke_unified_2024,
	title = {A unified machine learning framework for basketball team roster construction: {NBA} and {WNBA}},
	volume = {153},
	issn = {15684946},
	shorttitle = {A unified machine learning framework for basketball team roster construction},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1568494624000723},
	doi = {10.1016/j.asoc.2024.111298},
	abstract = {The National Basketball Association (NBA) is known for its luxury tax and unique salary cap, which makes the selection of players crucial. Machine learning models are becoming increasingly promising in modelling sports problems. In this paper, we present a unified framework that features a combination of unsupervised and supervised machine learning models for basketball team roster construction. In the unsupervised phase, we used principal components analysis (PCA) to reduce the number of features describing player performance and then applied a clustering approach to categorise them. In the supervised learning phase, we used a simple neural network to build a sports team model that gives the optimal combination of player types. We implemented a rating system for players by combining two weighting methods, considering their performing trends and ability under pressure. We apply the unified framework to the NBA and the Women’s National Basketball Association (WNBA). Our unified framework created the optimal team roster based on the clustering, team model, rates, and player salaries. Our framework for NBA identified 10 different clusters of players with 4 of them classified as elite clusters. The team model consists of 2 players from two elite clusters and the best players from the other 2 non-elite clusters.In our framework, we used different weighting methods for the evaluation of players’ performance. We found a strong link between the results and ground-truth of previous NBA matches and finally applied the framework to WNBA.},
	language = {en},
	urldate = {2025-06-26},
	journal = {Applied Soft Computing},
	author = {Ke, Yuhao and Bian, Ranran and Chandra, Rohitash},
	month = mar,
	year = {2024},
	keywords = {Read, Clustering, Roster},
	pages = {111298},
	file = {PDF:/home/admin/Zotero/storage/CHJ37PI2/Ke et al. - 2024 - A unified machine learning framework for basketball team roster construction NBA and WNBA.pdf:application/pdf},
}

